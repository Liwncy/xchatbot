{
    "name": "xchatbot",
    "version": "0.1.0",
    "private": true,
    "description": "Cloudflare Workers 消息处理机器人",
    "scripts": {
        "dev": "wrangler dev",
        "dev:scheduled": "wrangler dev --test-scheduled",
        "dev:remote": "wrangler dev --remote",
        "dev:pull": "npm run sync:pull && npm run dev",
        "typecheck": "tsc --noEmit",
        "plugin-admin:smoke": "tsc -p tsconfig.json --module commonjs --moduleResolution node --outDir .tmp-plugin-admin-smoke --rootDir src && node ./scripts/plugin-admin-smoke.cjs",
        "deploy": "wrangler deploy",
        "deploy:safe": "npm run sync:pull && npm run typecheck && npm run deploy",
        "deploy:safe:push": "npm run sync:push:force && npm run typecheck && npm run deploy",
        "sync:pull": "npm run sync:d1:remote-to-local && npm run sync:kv:remote-to-local",
        "sync:push": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/sync-push-safe.ps1",
        "sync:push:force": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/sync-push-safe.ps1 -Force",
        "sync:rollback:last": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/sync-rollback-last-push.ps1",
        "sync:rollback:last:force": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/sync-rollback-last-push.ps1 -Force",
        "sync:d1:local-to-remote": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/sync-d1-local-to-remote.ps1",
        "sync:kv:local-to-remote": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/sync-kv-local-to-remote.ps1",
        "d1:migrate:local": "wrangler d1 execute xbotdata --local --file \"./_docs/xiuxian/xiuxian-mvp.sql\"",
        "d1:migrate:remote": "wrangler d1 execute xbotdata --remote --file \"./_docs/xiuxian/xiuxian-mvp.sql\"",
        "d1:migrate:local:scheduler": "wrangler d1 execute xbotdata --local --file \"./_docs/scheduler/scheduler-mvp.sql\"",
        "d1:migrate:remote:scheduler": "wrangler d1 execute xbotdata --remote --file \"./_docs/scheduler/scheduler-mvp.sql\"",
        "d1:tables:local": "wrangler d1 execute xbotdata --local --command \"SELECT name FROM sqlite_master WHERE type='table' ORDER BY name;\"",
        "d1:tables:remote": "wrangler d1 execute xbotdata --remote --command \"SELECT name FROM sqlite_master WHERE type='table' ORDER BY name;\"",
        "kv:seed:local": "wrangler kv key put --binding XBOT_KV \"plugins:common:mapping\" --path \"./_docs/plugin-config/common-plugins.json\" --local && wrangler kv key put --binding XBOT_KV \"plugins:parameterized:mapping\" --path \"./_docs/plugin-config/common-plugins-dynamic.json\" --local && wrangler kv key put --binding XBOT_KV \"plugins:workflow:mapping\" --path \"./_docs/plugin-config/common-plugins-workflow.json\" --local",
        "kv:seed:remote": "wrangler kv key put --binding XBOT_KV \"plugins:common:mapping\" --path \"./_docs/plugin-config/common-plugins.json\" --remote && wrangler kv key put --binding XBOT_KV \"plugins:parameterized:mapping\" --path \"./_docs/plugin-config/common-plugins-dynamic.json\" --remote && wrangler kv key put --binding XBOT_KV \"plugins:workflow:mapping\" --path \"./_docs/plugin-config/common-plugins-workflow.json\" --remote",
        "kv:list:remote": "wrangler kv key list --binding XBOT_KV --remote",
        "kv:get:local:common": "wrangler kv key get --binding XBOT_KV \"plugins:common:mapping\" --local",
        "kv:get:local:dynamic": "wrangler kv key get --binding XBOT_KV \"plugins:parameterized:mapping\" --local",
        "kv:get:local:workflow": "wrangler kv key get --binding XBOT_KV \"plugins:workflow:mapping\" --local",
        "kv:set:local:ai-dialog-config": "wrangler kv key put --binding XBOT_KV \"plugins:ai-dialog:config\" --path \"./_docs/ai/ai-dialog-config.sample.json\" --local",
        "kv:get:local:ai-dialog-config": "wrangler kv key get --binding XBOT_KV \"plugins:ai-dialog:config\" --local",
        "kv:set:local:ai-sing-config": "wrangler kv key put --binding XBOT_KV \"plugins:ai-sing:config\" --path \"./_docs/ai/mimo-tts-config.sample.json\" --local",
        "kv:get:local:ai-sing-config": "wrangler kv key get --binding XBOT_KV \"plugins:ai-sing:config\" --local",
        "kv:set:local:xiuxian:set-config": "wrangler kv key put --binding XBOT_KV \"xiuxian:equipment:set-config\" --path \"./_docs/xiuxian/xiuxian-set-config.sample.json\" --local",
        "kv:get:local:xiuxian:set-config": "wrangler kv key get --binding XBOT_KV \"xiuxian:equipment:set-config\" --local",
        "kv:get:remote:common": "wrangler kv key get --binding XBOT_KV \"plugins:common:mapping\" --remote",
        "kv:get:remote:dynamic": "wrangler kv key get --binding XBOT_KV \"plugins:parameterized:mapping\" --remote",
        "kv:get:remote:workflow": "wrangler kv key get --binding XBOT_KV \"plugins:workflow:mapping\" --remote",
        "kv:set:remote:ai-dialog-config": "wrangler kv key put --binding XBOT_KV \"plugins:ai-dialog:config\" --path \"./_docs/ai/ai-dialog-config.sample.json\" --remote",
        "kv:get:remote:ai-dialog-config": "wrangler kv key get --binding XBOT_KV \"plugins:ai-dialog:config\" --remote",
        "kv:set:remote:ai-sing-config": "wrangler kv key put --binding XBOT_KV \"plugins:ai-sing:config\" --path \"./_docs/ai/mimo-tts-config.sample.json\" --remote",
        "kv:get:remote:ai-sing-config": "wrangler kv key get --binding XBOT_KV \"plugins:ai-sing:config\" --remote",
        "kv:get:remote:xiuxian:set-config": "wrangler kv key get --binding XBOT_KV \"xiuxian:equipment:set-config\" --remote",
        "sync:d1:remote-to-local": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/sync-d1-remote-to-local.ps1",
        "sync:kv:remote-to-local": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/sync-kv-remote-to-local.ps1",
        "kv:set:remote:xiuxian:set-config": "wrangler kv key put --binding XBOT_KV \"xiuxian:equipment:set-config\" --path \"./_docs/xiuxian/xiuxian-set-config.sample.json\" --remote",
        "dev:seed": "npm run kv:seed:local && npm run dev"
    },
    "dependencies": {
        "axios": "^1.12.2"
    },
    "devDependencies": {
        "@cloudflare/workers-types": "^4.20250224.0",
        "@types/node": "^25.3.3",
        "typescript": "^5.8.2",
        "wrangler": "^4.70.0"
    }
}
